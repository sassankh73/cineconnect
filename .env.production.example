# .env.production.example — committed template, NO real secrets.
# Copy these keys into your Vercel project (Settings → Environment Variables) and
# fill them with real values. Never commit the filled-in version.

# ---- Session / crypto secrets (generate each with: openssl rand -base64 32) ----
JWT_SECRET=
REFRESH_SECRET=
NEXTAUTH_SECRET=
NID_ENC_KEY=

# ---- Public app URL (drives email links + OAuth redirect URIs) ----
NEXTAUTH_URL=https://YOUR_DOMAIN

# ---- Session lifetimes ----
SESSION_MAX_AGE_SECONDS=86400
SESSION_REMEMBER_ME_SECONDS=2592000

# ---- Password hashing (install argon2 in production: npm i argon2) ----
AUTH_USE_ARGON2=1
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ---- Email provider (set ONE; priority Resend > SendGrid > SMTP) ----
RESEND_API_KEY=
# SENDGRID_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
EMAIL_FROM=noreply@cineconnect.ir

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#   Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google

# ---- Microsoft OAuth ----
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
#   Redirect URI: https://YOUR_DOMAIN/api/auth/callback/microsoft

# ---- Apple OAuth (Sign in with Apple) ----
APPLE_CLIENT_ID=com.yourapp.signin
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
#   Return URL: https://YOUR_DOMAIN/api/auth/callback/apple

# ---- Database (when migrating off the JSON store) ----
DATABASE_URL=
# PGSSL=require
