# Copy to .env.local and set strong values in production.
# Full auth reference + provider setup: see AUTH_SETUP.md

# JWT signing secrets (HttpOnly cookie sessions) — openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_SECRET=change-me-to-another-long-random-string
NEXTAUTH_SECRET=change-me-to-another-long-random-string

# AES-256-GCM key material for National ID encryption at rest
NID_ENC_KEY=change-me-to-a-strong-secret

# Public app URL (email links + OAuth redirect URIs)
NEXTAUTH_URL=http://localhost:3000

# Session lifetimes (seconds): default 24h, remember-me 30d
SESSION_MAX_AGE_SECONDS=86400
SESSION_REMEMBER_ME_SECONDS=2592000

# --- Email (optional locally → dev outbox at data/outbox.json) ---
# Set ONE provider; priority Resend > SendGrid > SMTP.
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
EMAIL_FROM=noreply@cineconnect.ir

# --- OAuth (optional; see AUTH_SETUP.md for provider setup) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT=common
# APPLE_CLIENT_ID=com.yourapp.signin
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Password hashing (optional; bcrypt by default, argon2 if installed) ---
# AUTH_USE_ARGON2=1
# ARGON2_MEMORY_COST=65536
# ARGON2_TIME_COST=3
# ARGON2_PARALLELISM=4

# --- Production integrations (not required for the local demo) ---
# DATABASE_URL=postgres://user:pass@localhost:5432/cineconnect
# S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
# S3_BUCKET=cineconnect-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# ZARINPAL_MERCHANT_ID=
# IDPAY_API_KEY=
