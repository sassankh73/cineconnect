# Copy to .env.local and set strong values in production.

# JWT signing secrets (HttpOnly cookie sessions)
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_SECRET=change-me-to-another-long-random-string

# AES-256-GCM key material for National ID encryption at rest
NID_ENC_KEY=change-me-to-a-strong-secret

# --- Production integrations (not required for the local demo) ---
# DATABASE_URL=postgres://user:pass@localhost:5432/cineconnect
# S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
# S3_BUCKET=cineconnect-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# ZARINPAL_MERCHANT_ID=
# IDPAY_API_KEY=
